@startuml
!theme plain
skinparam roundcorner 5
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor white
    ArrowColor #2688d4
    BorderColor #2688d4
}

entity "Users" as users {
  * id : INTEGER <<PK>>
  --
  * name : TEXT
  * role : TEXT
}

entity "Projects" as projects {
  * id : INTEGER <<PK>>
  --
  * name : TEXT
}

entity "Time_Entries" as time_entries {
  * id : INTEGER <<PK>>
  --
  * user_id : INTEGER <<FK>>
  * project_id : INTEGER <<FK>>
  * start_time : TEXT
  * end_time : TEXT
  * duration_seconds : INTEGER
  * description : TEXT
  * status : TEXT
}

users ||--o{ time_entries : "Создает записи"
projects ||--o{ time_entries : "Включает записи"
@enduml